# ───────────────────────────────────────────────────────────────────
#                   PRISM LOCAL & PRODUCTION SETUP
# ───────────────────────────────────────────────────────────────────
# Copy this file to ".env" in local development.
# NEVER commit your credentials to source control.

# ── 1. GOOGLE GEMINI API KEY ──────────────────────────────────────
# Obtain your free API key from Google AI Studio:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── 2. FIREBASE APP CREDENTIALS ───────────────────────────────────
# Create a free Firebase project, register a "Web App", and paste those values here.
# Note: Variables prefixed with 'VITE_' are automatically injected into the browser build.
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_ID=(default)

# ── 3. ADMINISTRATIVE BACKUP KEY ──────────────────────────────────
# Authentication key for streaming backups from Cloud Run to local machine.
# Keep this secure. Use it in 'X-Admin-Key' header when calling '/api/admin/export-db'
ADMIN_EXPORT_KEY=PrismBackup2026

# ── 4. HOSTING & COMPILER VARIABLES ───────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
